{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MacroMineralPolicyExtraction",
  "type": "object",
  "properties": {
    "is_valid_macro_policy": {
      "type": "boolean",
      "description": "【最高优先级杀伤开关】仔细阅读输入文本。如果该文本是：1. 网页导航栏或免责声明；2. 与跨国矿产毫无关联的微观社会新闻（如车展、劫案）；3. 毫无实质性约束条款的论坛口水宣言；4. 纯国内的区域发展政策（未涉及跨境贸易壁垒）。你必须立刻填 false！只有遇到真正的跨国关键矿产、地缘博弈、合规审查等实质性政策，才填 true。"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "country": {
          "type": "string",
          "description": "政策颁布国家或地区，使用ISO标准二字码，如 CN, ID, ZW, CD, EU"
        },
        "mineral_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Lithium",
              "Cobalt",
              "Nickel",
              "Copper",
              "Rare Earths",
              "Graphite",
              "Others"
            ]
          },
          "description": "涉及的关键矿产种类"
        },
        "policy_source_type": {
          "type": "string",
          "enum": [
            "Official_Gazette",
            "Ministry_Website",
            "Customs_Announcement",
            "Tier1_Commodity_Media"
          ],
          "description": "信息源头分类"
        },
        "issuing_authority": {
          "type": "string",
          "description": "政策颁布主体/发起机构全称（如：欧盟委员会、世界银行、美国能源部DOE、印尼能矿部ESDM、中国发改委、中国商务部）。必须从原文提炼，不得为空。若原文无明确机构则填发布国/地区政府全称。"
        }
      },
      "required": [
        "country",
        "mineral_types",
        "policy_source_type",
        "issuing_authority"
      ]
    },
    "policy_dynamics": {
      "type": "object",
      "properties": {
        "policy_name_zh": {
          "type": "string",
          "description": "情报级高管标题。必须采用强结构化公式：【[国家二字码] {颁布主体}核心动作与定量影响：法案核心 (涉及矿种)】。标题必须显式包含颁布主体/发起机构（如『欧盟委员会』『世界银行』『印尼能矿部』），绝不允许只写空泛名词或缺主语！正确范例：『[EU] 欧盟委员会通过关键矿产供应链尽责法案：或提升新能源矿产合规成本 (锂/钴/镍)』『[ID] 印尼能矿部(ESDM)加征15%出口税：铜精矿出口新规 (铜/镍)』；错误范例：『推动关键矿产供应链尽责管理倡议』（缺颁布主体）『印尼出口新规』（缺主体且空泛）。"
        },
        "policy_name_original": {
          "type": "string",
          "description": "政策/法案的原语言全称"
        },
        "current_stage": {
          "type": "string",
          "enum": [
            "Proposal",
            "Under_Debate",
            "Approved_Not_Effective",
            "Fully_Effective",
            "Suspended"
          ],
          "description": "政策所处的最新法律/行政阶段"
        },
        "effective_date": {
          "type": "string",
          "format": "date",
          "description": "正式生效日期，若未知则填空"
        },
        "policy_dimension": {
          "type": "string",
          "enum": [
            "Trade_Restriction",
            "Resource_Sovereignty",
            "Supply_Chain_Governance",
            "ESG_Compliance",
            "Industrial_Policy",
            "Green_Transition"
          ],
          "description": "政策的一级维度分类（兜底维度标签）"
        },
        "core_category": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Export_Ban",
              "Export_Restriction",
              "Resource_Nationalism",
              "Beneficiation_Mandate",
              "Tariff_Adjustment",
              "Foreign_Equity_Restriction",
              "Tax_Royalties_Change",
              "Supply_Chain_Due_Diligence",
              "State_Procurement_Monopoly",
              "ESG_Compliance_Mandate",
              "Strategic_Stockpile",
              "Price_Control_Subsidy",
              "Carbon_Border_Mechanism",
              "Critical_Minerals_Strategy",
              "Green_Subsidy_IRA"
            ]
          },
          "description": "政策核心手段分类（支持多选）"
        },
        "substantive_provisions": {
          "type": "string",
          "description": "核心条款的结构化拆解（限300字内，直奔主题，拒绝修饰词）"
        }
      },
      "required": [
        "policy_name_zh",
        "current_stage",
        "policy_dimension",
        "core_category",
        "substantive_provisions"
      ]
    },
    "strategic_implications": {
      "type": "object",
      "properties": {
        "supply_chain_impact_level": {
          "type": "string",
          "enum": [
            "High_Disruption",
            "Moderate_Adjustment",
            "Low_Monitoring"
          ],
          "description": "对垂直一体化供应链的潜在冲击烈度评估"
        },
        "impact_deduction": {
          "type": "string",
          "description": "基于专业顾问视角的深度推演。需包含：1. 对现有海外产能布局的直接波及；2. 对中下游冶炼/前驱体成本的传导效应；3. 替代路线或对策建议。对于 ESG/供应链尽责类政策，需额外推演合规成本与跨境合规风险。"
        }
      },
      "required": [
        "supply_chain_impact_level",
        "impact_deduction"
      ]
    },
    "news_recency_verification": {
      "type": "object",
      "description": "【v3.5 时效性校验 — 第二道防线】后端 pubDate 无法覆盖的源（anyfeeder/HTML），由 LLM 兜底判断该文章报道的是否为近期新政策，而非历史旧规回顾。",
      "properties": {
        "is_recent_policy_action": {
          "type": "boolean",
          "description": "原文中报道的政策/法案/行政令是近期（本年度内）新颁布、新修订或新提出的实质性动作吗？若原文纯粹回顾历史旧规、介绍已存在多年的倡议、或追述往年政策而没有任何新进展，填 false。"
        },
        "declared_publish_year": {
          "type": [
            "integer",
            "null"
          ],
          "description": "若能推断出该政策的颁布/修订年份，填四位年份数字（如 2026）；若完全无法判断则填 null。供后端二次交叉校验。"
        }
      },
      "required": [
        "is_recent_policy_action"
      ]
    },
    "notion_integration": {
      "type": "object",
      "properties": {
        "master_tag": {
          "type": "string",
          "const": "宏观地缘与产业政策"
        },
        "dingtalk_alert_required": {
          "type": "boolean",
          "description": "若冲击烈度为 High_Disruption 或 Moderate_Adjustment，强制为 true；Low_Monitoring 强制为 false"
        },
        "source_article_url": {
          "type": "string",
          "description": "从原始情报文本中提取的政策全文/官方公告链接，供回溯溯源"
        }
      },
      "required": [
        "master_tag",
        "dingtalk_alert_required"
      ]
    }
  },
  "required": [
    "is_valid_macro_policy",
    "metadata",
    "policy_dynamics",
    "strategic_implications",
    "news_recency_verification",
    "notion_integration"
  ]
}
